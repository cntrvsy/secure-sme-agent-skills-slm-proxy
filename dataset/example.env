# Gemini API Key configuration (used for datasets sanitization)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
BATCH_SIZE=5
# Delay in seconds between batched requests to stay within Free Tier RPM (15 RPM -> 5.0 seconds delay)
REQUEST_DELAY=5.0

# Hugging Face Authentication Token (Highly recommended to prevent rate limits)
HF_TOKEN=your_hugging_face_token_here

# Unsloth Fine-Tuning Parameters
MODEL_NAME=unsloth/gemma-4-E2B-it
DATASET_NAME=cntrvsy/synthezised_sme_poisoned_skillsmd
MAX_STEPS=500
# Epochs override max_steps if set (e.g. EPOCHS=2)
EPOCHS=
# Quantization method for GGUF export (options: q4_k_m, q5_k_m, q8_0, f16)
GGUF_QUANT=q4_k_m
# Load model in 4-bit precision to reduce VRAM (options: True, False)
LOAD_IN_4BIT=False

# Model Export Directories
OUTPUT_DIR=outputs
LORA_DIR=gemma4_e2b_skillmd_sanitizer_lora
MERGED_DIR=gemma4_e2b_skillmd_sanitizer_merged
GGUF_DIR=gemma4_e2b_skillmd_sanitizer_gguf
