# Gemini API Key configuration (used for datasets sanitization)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
BATCH_SIZE=5
# Delay in seconds between batched requests to stay within Free Tier RPM (15 RPM -> 5.0 seconds delay)
REQUEST_DELAY=5.0

# Hugging Face Access Token (Recommended)
HF_TOKEN=your_hugging_face_token_here

# Unsloth Fine-Tuning Parameters (Optimized for 14GB RAM / 180W GPU System)
MODEL_NAME=unsloth/Qwen2.5-3B-Instruct
DATASET_NAME=cntrvsy/synthezised_sme_poisoned_skillsmd
MAX_STEPS=500
# Epochs override max_steps if set (e.g. EPOCHS=2)
EPOCHS=
# Quantization method for GGUF export (options: q4_k_m, q5_k_m, q8_0, f16)
GGUF_QUANT=q4_k_m
# Export as standard single-file text GGUF (Qwen2.5 format) to bypass vision/projector split for LM Studio
EXPORT_TEXT_ONLY=True
# Load model in 4-bit precision (False for 16-bit to avoid AMD/bnb segfault)
LOAD_IN_4BIT=False

# Hardware Stability Options (Preventing Power/VRAM Spikes)
# Batch size per device (default 2 fits comfortably in 16GB VRAM for 3B models)
BATCH_SIZE_FT=2
# Gradient accumulation steps
GRAD_ACCUM=4

# Model Export Directories
OUTPUT_DIR=outputs
LORA_DIR=qwen2_5_3b_skillmd_sanitizer_lora
MERGED_DIR=qwen2_5_3b_skillmd_sanitizer_merged
GGUF_DIR=qwen2_5_3b_skillmd_sanitizer_gguf
